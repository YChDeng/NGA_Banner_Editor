{
  "name": "nga-bbcode-preview",
  "version": "0.1.0",
  "private": true,
  "description": "Local Electron GUI for previewing NGA BBCode.",
  "main": "src/main.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer-entry.js --bundle --platform=browser --format=iife --loader:.ttf=file --loader:.css=css --outfile=dist/renderer.js && esbuild src/monaco-worker.js --bundle --platform=browser --format=iife --outfile=dist/monaco-worker.js",
    "test": "node --test tests/*.test.js",
    "start": "npm run build:renderer && electron .",
    "benchmark": "node scripts/benchmark.js"
  },
  "devDependencies": {
    "electron": "latest",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "monaco-editor": "^0.55.1"
  }
}
