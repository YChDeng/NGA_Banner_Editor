{
  "name": "nga-bbcode-preview",
  "version": "0.1.0",
  "private": true,
  "description": "Local Electron GUI for previewing NGA BBCode.",
  "main": "src/main.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer-entry.js --bundle --platform=browser --format=iife --outfile=dist/renderer.js",
    "test": "node --test tests/*.test.js",
    "start": "npm run build:renderer && electron .",
    "benchmark": "node scripts/benchmark.js"
  },
  "devDependencies": {
    "electron": "latest",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6"
  }
}
